# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================
# Environment files — NEVER commit secrets
# ============================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
!.env.example

# ============================================
# Secrets — keys, certificates, credentials
# ============================================
*.key
*.pem
*.p12
*.pfx
*.jks
*.keystore
*.secret
credentials.json
service-account*.json
gcloud-*.json

# ============================================
# Database files (local dev only)
# ============================================
dev.db
dev.db-journal
*.sqlite3

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma generated
/src/generated/prisma

# Infisical (removed)
infisical.json
