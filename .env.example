# ============================================
# GuiaHóspedes — Variáveis de Ambiente
# ============================================
# 
# AMBIENTE DE DESENVOLVIMENTO LOCAL:
# 1. Copie este arquivo para .env
# 2. Preencha os valores necessários
# 3. NUNCA faça commit do arquivo .env
#
# AMBIENTE DE PRODUÇÃO (Railway + Neon):
# Configure estas variáveis diretamente no dashboard do Railway.
# Veja o guia completo em: DEPLOY_PROD.md
# ============================================

# ============================================
# BANCO DE DADOS — OBRIGATÓRIO
# ============================================
# Desenvolvimento (SQLite local):
DATABASE_URL="file:./dev.db"
#
# Produção (Neon PostgreSQL):
# DATABASE_URL="postgresql://usuario:senha@ep-xxx.us-east-1.aws.neon.tech/nome_banco?sslmode=require"

# ============================================
# AUTENTICAÇÃO — OBRIGATÓRIO
# ============================================
# Desenvolvimento:
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="dev-secret-change-in-production"
#
# Produção:
# NEXTAUTH_URL="https://seu-app.up.railway.app"
# NEXTAUTH_SECRET="sua-chave-secreta-gerada-com-openssl-rand-base64-32"

# ============================================
# APLICAÇÃO — OBRIGATÓRIO
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="GuiaHóspedes"
#
# Produção:
# NEXT_PUBLIC_APP_URL="https://seu-app.up.railway.app"

# ============================================
# E-MAIL — OPCIONAL (ativar quando configurar SMTP)
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@guiahospedes.com"

# ============================================
# ARMAZENAMENTO — OPCIONAL
# ============================================
STORAGE_PROVIDER="local"

# ============================================
# INTEGRAÇÕES — OPCIONAL (ativar quando necessário)
# ============================================
AIRBNB_ICAL_ENABLED="true"
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# ============================================
# REDIS — OPCIONAL (para filas BullMQ)
# ============================================
# REDIS_URL="redis://localhost:6379"
