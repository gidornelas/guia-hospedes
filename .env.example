# ============================================
# GuiaHospedes - Variaveis de ambiente
# ============================================
# 1. Copie este arquivo para .env
# 2. Preencha os valores necessarios
# 3. Nunca faca commit do .env real

# ============================================
# Banco de dados - obrigatorio
# ============================================
DATABASE_URL="postgresql://usuario:senha@host/database?sslmode=require"
# Dica: para desenvolvimento, use um banco PostgreSQL local ou um projeto Neon.

# ============================================
# Aplicacao - obrigatorio
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="GuiaHospedes"

# ============================================
# Sessao - obrigatorio
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="troque-por-um-secret-forte"

# ============================================
# Login com Google - opcional
# ============================================
# Crie uma credencial OAuth Web no Google Cloud Console
# Redirect URI local: http://localhost:3000/api/auth/google/callback
# Redirect URI producao: https://seu-dominio.com/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# E-mail / recuperacao de senha - opcional
# ============================================
# Para Gmail SMTP, use uma senha de app em SMTP_PASS.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@guiahospedes.com"

# ============================================
# Armazenamento - opcional
# ============================================
STORAGE_PROVIDER="local"

# ============================================
# Integracoes - opcional
# ============================================
AIRBNB_ICAL_ENABLED="true"
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# ============================================
# Redis - opcional
# ============================================
# REDIS_URL="redis://localhost:6379"
