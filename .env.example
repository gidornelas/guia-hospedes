# ============================================
# GuiaHospedes - Variaveis de ambiente
# ============================================
# 1. Copie este arquivo para .env
# 2. Preencha os valores necessarios
# 3. Nunca faca commit do .env real

# ============================================
# Banco de dados - obrigatorio
# ============================================
DATABASE_URL="postgresql://usuario:senha@host/database?sslmode=require"
# Dica: para desenvolvimento, use um banco PostgreSQL local ou um projeto Neon.

# ============================================
# Aplicacao - obrigatorio
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="GuiaHospedes"

# ============================================
# Sessao / JWT - obrigatorio
# ============================================
# Use um secret forte (minimo 32 caracteres).
# Gere com: openssl rand -base64 32
AUTH_SECRET="troque-por-um-secret-forte-de-32-chars"

# ============================================
# Login com Google - opcional
# ============================================
# Crie uma credencial OAuth Web no Google Cloud Console
# Redirect URI local: http://localhost:3000/api/auth/google/callback
# Redirect URI producao: https://seu-dominio.com/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ============================================
# E-mail / recuperacao de senha - opcional
# ============================================
# Para Gmail SMTP, use uma senha de app em SMTP_PASS.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@guiahospedes.com"

# ============================================
# Armazenamento - opcional
# ============================================
# Provedores suportados: 'local' (padrão), 's3', 'r2'
STORAGE_PROVIDER="local"

# Configuração S3/R2 (obrigatório se STORAGE_PROVIDER for s3 ou r2)
S3_ENDPOINT=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
# URL pública base para arquivos (ex: https://cdn.seudominio.com ou https://<bucket>.s3.<region>.amazonaws.com)
S3_PUBLIC_URL=""

# ============================================
# Integracoes - opcional
# ============================================
AIRBNB_ICAL_ENABLED="true"
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""

# ============================================
# Traducao automatica - opcional
# ============================================
# Provedores suportados:
#   'libretranslate' — padrao, gratuito/open-source, nao precisa de chave
#   'deepl' — requer chave de API (free ou pro)
#   'google' — requer chave do Google Cloud
TRANSLATION_API_PROVIDER="libretranslate"
TRANSLATION_API_KEY=""
# URL customizada do LibreTranslate (opcional, para self-hosting)
# LIBRETRANSLATE_URL="https://libretranslate.de/translate"

# ============================================
# Redis - opcional
# ============================================
# REDIS_URL="redis://localhost:6379"
